"""checkllm tests for chatbot quality and safety.

Generated by checkllm init.
"""


def test_chatbot_output_quality(check):
    """Test that your chatbot produces safe, relevant, fluent responses."""
    # Replace with your actual chatbot call
    query = "How can I reset my password?"
    output = "To reset your password, go to Settings > Security > Reset Password."

    # Deterministic checks (free, instant)
    check.contains(output, "password")
    check.max_tokens(output, limit=300)
    check.no_pii(output)

    # LLM-as-judge checks (requires API key)
    check.relevance(output, query=query)
    check.toxicity(output)
    check.fluency(output)
    check.instruction_following(
        output,
        instructions="Respond helpfully and concisely. Do not share personal data.",
    )
