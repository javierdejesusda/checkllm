def test_agent_output_quality(check):
    """Test that your agent completes tasks accurately."""
    # Replace with your actual agent call
    output = "I've searched the database and found 3 matching records."
    task = "Search the database for records matching the user's query."

    # Deterministic checks (free, instant)
    check.max_tokens(output, limit=500)
    check.no_pii(output)

    # LLM-as-judge checks (requires API key)
    check.task_completion(output, task_description=task)
    check.relevance(output, query=task)
    check.toxicity(output)
