def test_output_quality(check):
    """Test basic LLM output quality."""
    # Replace with your actual LLM call
    output = "Python is a high-level programming language."

    # Deterministic checks (free, instant, no API key needed)
    check.contains(output, "Python")
    check.not_contains(output, "undefined")
    check.max_tokens(output, limit=200)
    check.no_pii(output)

