name: checkllm

on:
  pull_request:
    branches: [main]

jobs:
  eval:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"
      - run: pip install checkllm[all] pytest
      - run: checkllm run tests/ --budget 5.0
        env:
          OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}
