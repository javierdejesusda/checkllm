def test_rag_output_quality(check):
    """Test that your RAG pipeline produces faithful, relevant answers."""
    # Replace with your actual RAG pipeline call
    query = "What is Python?"
    context = "Python is a high-level programming language created by Guido van Rossum."
    output = "Python is a high-level programming language."

    # Deterministic checks (free, instant)
    check.contains(output, "Python")
    check.max_tokens(output, limit=500)
    check.no_pii(output)

    # LLM-as-judge checks (requires API key)
    check.hallucination(output, context=context)
    check.faithfulness(output, context=context, query=query)
    check.relevance(output, query=query)
    check.context_relevance(context=context, query=query)
